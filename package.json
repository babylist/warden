{
  "name": "warden-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "cli": "pnpm --filter @sentry/warden cli",
    "clean:dist": "rm -rf dist packages/*/dist",
    "build": "pnpm --filter @sentry/warden build",
    "build:action": "pnpm --filter @sentry/warden build:action",
    "dev": "pnpm --filter @sentry/warden dev",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "pnpm --filter @sentry/warden test",
    "test:coverage": "pnpm --filter @sentry/warden test:coverage",
    "test:watch": "pnpm --filter @sentry/warden test:watch",
    "test:examples": "pnpm --filter @sentry/warden test:examples",
    "evals": "pnpm -C packages/evals evals",
    "evals:scaffold": "pnpm -C packages/evals scaffold",
    "typecheck": "pnpm --filter @sentry/warden typecheck && pnpm -C packages/evals typecheck",
    "update-pricing": "pnpm --filter @sentry/warden update-pricing",
    "update-pricing-pr": "pnpm --filter @sentry/warden update-pricing-pr",
    "generate:jsonl-schema": "pnpm --filter @sentry/warden generate:jsonl-schema",
    "docs": "pnpm --filter warden-docs dev",
    "prepare": "simple-git-hooks",
    "pack:warden": "pnpm --filter @sentry/warden pack"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm typecheck"
  },
  "lint-staged": {
    "packages/warden/src/**/*.ts": [
      "oxlint --fix"
    ],
    "packages/evals/src/**/*.ts": [
      "oxlint --fix"
    ],
    "packages/evals/scripts/**/*.ts": [
      "oxlint --fix"
    ],
    "packages/evals/*.ts": [
      "oxlint --fix"
    ],
    "packages/docs/**/*.astro": [
      "pnpm -C packages/docs build"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@vercel/ncc": "^0.38.4",
    "@vitest/coverage-v8": "^4.1.7",
    "ink-testing-library": "^4.0.0",
    "lint-staged": "^17.0.5",
    "oxlint": "^1.66.0",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
