# Source files (dist/ is published). Internal skill assets are runtime data.
src/*
!src/internal-skills/
!src/internal-skills/**
!src/builtin-skills/
!src/builtin-skills/**

# GitHub Action bundle (only needed for action, not npm)
dist/action/
action.yml

# Test files
*_test.py
*.test.ts
*.test.js
*.test.d.ts
**/*.test.*
vitest*.config.ts
coverage/

# Environment and secrets (.npmignore overrides .gitignore)
.env
.env.*

# Development/CI files
.github/
.agents/
.codex/
.cursor/
.warden/
.claude/
.dex/
.context/
*.config.js
tsconfig*.json
pnpm-lock.yaml
pnpm-workspace.yaml

# Evals and dev scripts
/scripts/
superwarden-bench/

# Plugin/agent config (not needed by npm consumers)
plugins/
.claude-plugin/
.mcp.json
agents.toml
conductor.json

# Release tooling
.craft.yml
bin/*
!bin/warden.js

# Documentation (README is kept)
AGENTS.md
CLAUDE.md
CONTRIBUTING.md
/SPEC.md
docs/
packages/
assets/
specs/

# Example config
warden.toml
