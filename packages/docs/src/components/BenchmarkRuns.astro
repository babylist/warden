---
type BenchmarkScoring = {
  knownFindingCount: number;
  knownFound: number;
  knownFoundRate?: number;
  knownMissed: number;
};

type TimingDistribution = {
  count: number;
  max: number;
  p50: number;
  p75: number;
  p90: number;
  p95: number;
  source: string;
  total?: number;
};

type BenchmarkResult = {
  corpusId: string;
  model: string;
  reasoningLevel?: string;
  runId: string;
  runtime: string;
  scoring?: BenchmarkScoring;
  skill: string;
  summary: {
    analysisCostUSD: number;
    auxiliaryCostUSD: number;
    chunksAnalyzed: number;
    chunksFailed: number;
    chunksTotal: number;
    costUSD: number;
    durationMs: number;
    findingsTotal: number;
    inputTokens?: number;
    outputTokens?: number;
    skippedFileCount?: number;
  };
  supersededBy?: string;
  targetMode: string;
  timing?: {
    analysisChunkMs?: TimingDistribution;
    shardWallMs?: TimingDistribution;
  };
};

const MODEL_LABELS: Record<string, string> = {
  "anthropic/claude-opus-4-6": "Claude Opus 4.6",
  "anthropic/claude-opus-4-7": "Claude Opus 4.7",
  "anthropic/claude-opus-4-8": "Claude Opus 4.8",
  "anthropic/claude-sonnet-4-6": "Claude Sonnet 4.6",
  "anthropic/claude-sonnet-5": "Claude Sonnet 5",
  "claude-opus-4-6": "Claude Opus 4.6",
  "claude-opus-4-7": "Claude Opus 4.7",
  "claude-opus-4-8": "Claude Opus 4.8",
  "claude-sonnet-4-6": "Claude Sonnet 4.6",
  "openai/gpt-5.5": "GPT 5.5",
  "openrouter/deepseek/deepseek-v4-flash": "DeepSeek V4 Flash",
  "openrouter/deepseek/deepseek-v4-pro": "DeepSeek V4 Pro",
};

const REASONING_LABELS: Record<string, string> = {
  high: "high",
  low: "low",
  "pi-default-medium": "medium",
  "provider-default": "default",
  xhigh: "xhigh",
};

const RUNTIME_LABELS: Record<string, string> = {
  claude: "Claude SDK",
  pi: "Pi",
};

const knownFoundRate = (scoring: BenchmarkScoring | undefined) =>
  scoring && scoring.knownFindingCount !== 0
    ? scoring.knownFound / scoring.knownFindingCount
    : undefined;

const resultModules = import.meta.glob<BenchmarkResult>(
  "../data/benchmarking/results/*.json",
  {eager: true, import: "default"},
);

const formatCost = (value: number) => `$${value.toFixed(2)}`;

const formatTokenCount = (value: number | undefined) =>
  value === undefined
    ? "n/a"
    : new Intl.NumberFormat("en-US", {
        compactDisplay: "short",
        maximumFractionDigits: 2,
        notation: "compact",
      }).format(value).toLowerCase();

const formatDuration = (value: number | undefined) => {
  if (value === undefined) {
    return "n/a";
  }
  if (value >= 60_000) {
    return `${(value / 60_000).toFixed(1)}m`;
  }
  return `${(value / 1000).toFixed(1)}s`;
};

const formatPercent = (value: number) => `${(value * 100).toFixed(1)}%`;

const modelLabel = (model: string) => MODEL_LABELS[model] ?? model;

const runtimeLabel = (runtime: string) => RUNTIME_LABELS[runtime] ?? runtime;

const reasoningLabel = (reasoningLevel: string | undefined) =>
  reasoningLevel ? REASONING_LABELS[reasoningLevel] : undefined;

const hidesReasoningLabel = (result: BenchmarkResult) =>
  result.model.includes("claude-sonnet");

const runLabel = (result: BenchmarkResult) =>
  `${modelLabel(result.model)} (${runtimeLabel(result.runtime)})`;

const runMeta = (result: BenchmarkResult) =>
  hidesReasoningLabel(result)
    ? ""
    : [reasoningLabel(result.reasoningLevel)].filter(Boolean).join(" · ");

const sortLabel = (result: BenchmarkResult) =>
  [runLabel(result), runMeta(result)].filter(Boolean).join(" ");

const compareResults = (a: BenchmarkResult, b: BenchmarkResult) => {
  const foundRateDiff =
    (knownFoundRate(b.scoring) ?? -1) - (knownFoundRate(a.scoring) ?? -1);
  if (foundRateDiff !== 0) {
    return foundRateDiff;
  }

  const knownFoundDiff =
    (b.scoring?.knownFound ?? -1) - (a.scoring?.knownFound ?? -1);
  if (knownFoundDiff !== 0) {
    return knownFoundDiff;
  }

  const findingsDiff = a.summary.findingsTotal - b.summary.findingsTotal;
  if (findingsDiff !== 0) {
    return findingsDiff;
  }

  const costDiff = a.summary.costUSD - b.summary.costUSD;
  if (costDiff !== 0) {
    return costDiff;
  }

  return sortLabel(a).localeCompare(sortLabel(b));
};

const stableResults = Object.values(resultModules)
  .filter(
    (result) =>
      result.corpusId === "sentry-vulnerability-corpus" &&
      result.targetMode === "all-corpus-files-by-sha" &&
      !result.supersededBy &&
      result.summary.chunksFailed === 0 &&
      (result.summary.skippedFileCount ?? 0) === 0 &&
      result.summary.chunksAnalyzed === result.summary.chunksTotal &&
      result.timing?.analysisChunkMs,
  );

const compareCostResults = (a: BenchmarkResult, b: BenchmarkResult) => {
  const costDiff = a.summary.costUSD - b.summary.costUSD;
  if (costDiff !== 0) {
    return costDiff;
  }

  return compareResults(a, b);
};

const compareTimingResults = (a: BenchmarkResult, b: BenchmarkResult) => {
  const aTiming = a.timing?.analysisChunkMs;
  const bTiming = b.timing?.analysisChunkMs;

  const p50Diff =
    (aTiming?.p50 ?? Number.POSITIVE_INFINITY) -
    (bTiming?.p50 ?? Number.POSITIVE_INFINITY);
  if (p50Diff !== 0) {
    return p50Diff;
  }

  const p90Diff =
    (aTiming?.p90 ?? Number.POSITIVE_INFINITY) -
    (bTiming?.p90 ?? Number.POSITIVE_INFINITY);
  if (p90Diff !== 0) {
    return p90Diff;
  }

  const totalDiff =
    (a.timing?.shardWallMs?.total ?? a.summary.durationMs) -
    (b.timing?.shardWallMs?.total ?? b.summary.durationMs);
  if (totalDiff !== 0) {
    return totalDiff;
  }

  return compareResults(a, b);
};

const scoreResults = [...stableResults].sort(compareResults);
const costResults = [...stableResults].sort(compareCostResults);
const timingResults = [...stableResults].sort(compareTimingResults);
---

<section class="benchmark-runs" aria-label="Stable benchmark comparison matrix">
  {stableResults.length === 0 ? (
    <p>No stable benchmark comparisons recorded yet.</p>
  ) : (
    <div class="run-table score-table" role="table" aria-label="Stable benchmark comparison scores">
      <div class="run-header" role="row">
        <span role="columnheader">Run</span>
        <span role="columnheader">Known</span>
        <span role="columnheader">Findings</span>
        <span role="columnheader">Cost</span>
      </div>
      {scoreResults.map((result) => {
        const scoring = result.scoring;
        const scoreRate = scoring ? knownFoundRate(scoring) : undefined;
        return (
          <article class="run-row" role="row">
            <div class="run-name" role="cell">
              <h3>
                {modelLabel(result.model)}{" "}
                <span>({runtimeLabel(result.runtime)})</span>
              </h3>
              {runMeta(result) && <p>{runMeta(result)}</p>}
            </div>
            <div class="metric-cell" role="cell">
              <span class="cell-label">Known corpus</span>
              <strong class="metric-value">
                {scoring
                  ? `${scoring.knownFound}/${scoring.knownFindingCount}`
                  : "Not scored"}
              </strong>
              {scoreRate !== undefined && <span class="metric-detail">{formatPercent(scoreRate)}</span>}
            </div>
            <div class="metric-cell" role="cell">
              <span class="cell-label">Total findings</span>
              <strong class="metric-value">{result.summary.findingsTotal}</strong>
            </div>
            <div class="metric-cell" role="cell">
              <span class="cell-label">Cost</span>
              <strong class="metric-value">{formatCost(result.summary.costUSD)}</strong>
            </div>
          </article>
        );
      })}
    </div>
  )}

  {stableResults.length > 0 && (
    <div class="detail-tables">
      <section class="detail-section" aria-labelledby="benchmark-cost-breakdown">
        <h3 id="benchmark-cost-breakdown">Cost</h3>
        <p class="sort-note">Lowest cost first.</p>
        <div class="detail-table-wrap">
          <div class="run-table cost-table" role="table" aria-label="Cost breakdown">
            <div class="run-header" role="row">
              <span role="columnheader">Run</span>
              <span role="columnheader">Cost</span>
              <span role="columnheader">Input</span>
              <span role="columnheader">Output</span>
            </div>
            {costResults.map((result) => (
              <article class="run-row" role="row">
                <div class="run-name" role="cell">
                  <h3>
                    {modelLabel(result.model)}{" "}
                    <span>({runtimeLabel(result.runtime)})</span>
                  </h3>
                  {runMeta(result) && <p>{runMeta(result)}</p>}
                </div>
                <div class="metric-cell" role="cell">
                  <span class="cell-label">Cost</span>
                  <strong class="metric-value">{formatCost(result.summary.costUSD)}</strong>
                </div>
                <div class="metric-cell" role="cell">
                  <span class="cell-label">Input</span>
                  <strong class="metric-value">{formatTokenCount(result.summary.inputTokens)}</strong>
                </div>
                <div class="metric-cell" role="cell">
                  <span class="cell-label">Output</span>
                  <strong class="metric-value">{formatTokenCount(result.summary.outputTokens)}</strong>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="detail-section" aria-labelledby="benchmark-timing-breakdown">
        <h3 id="benchmark-timing-breakdown">Timing</h3>
        <p class="sort-note">Lowest P50 chunk duration first.</p>
        <div class="detail-table-wrap">
          <div class="run-table timing-table" role="table" aria-label="Timing breakdown">
            <div class="run-header" role="row">
              <span role="columnheader">Run</span>
              <span role="columnheader">P50</span>
              <span role="columnheader">P90</span>
              <span role="columnheader">Total</span>
            </div>
            {timingResults.map((result) => {
              const chunkTiming = result.timing?.analysisChunkMs;
              const shardTiming = result.timing?.shardWallMs;
              return (
                <article class="run-row" role="row">
                  <div class="run-name" role="cell">
                    <h3>
                      {modelLabel(result.model)}{" "}
                      <span>({runtimeLabel(result.runtime)})</span>
                    </h3>
                    {runMeta(result) && <p>{runMeta(result)}</p>}
                  </div>
                  <div class="metric-cell" role="cell">
                    <span class="cell-label">P50</span>
                    <strong class="metric-value">{formatDuration(chunkTiming?.p50)}</strong>
                  </div>
                  <div class="metric-cell" role="cell">
                    <span class="cell-label">P90</span>
                    <strong class="metric-value">{formatDuration(chunkTiming?.p90)}</strong>
                  </div>
                  <div class="metric-cell" role="cell">
                    <span class="cell-label">Total</span>
                    <strong class="metric-value">{formatDuration(shardTiming?.total ?? result.summary.durationMs)}</strong>
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      </section>
    </div>
  )}
</section>

<style>
  .benchmark-runs {
    margin: 1rem 0 1.5rem;
  }

  .benchmark-runs .run-table,
  .benchmark-runs .run-header,
  .benchmark-runs .run-row,
  .benchmark-runs .run-header > *,
  .benchmark-runs .run-row > *,
  .benchmark-runs .run-name h3,
  .benchmark-runs .run-name p,
  .benchmark-runs .metric-value,
  .benchmark-runs .metric-detail,
  .benchmark-runs .cell-label,
  .benchmark-runs .detail-section h3,
  .benchmark-runs .sort-note {
    margin: 0;
  }

  .run-table {
    border: 1px solid var(--sl-color-gray-6);
    border-radius: 8px;
    overflow: hidden;
    width: 100%;
  }

  .run-header,
  .run-row {
    display: grid;
  }

  .score-table .run-header,
  .score-table .run-row {
    grid-template-columns: minmax(12rem, 1fr) repeat(3, minmax(5.4rem, 0.34fr));
  }

  .cost-table .run-header,
  .cost-table .run-row {
    grid-template-columns: minmax(13rem, 1fr) minmax(6.3rem, 0.44fr) repeat(2, minmax(6.8rem, 0.46fr));
  }

  .timing-table .run-header,
  .timing-table .run-row {
    grid-template-columns: minmax(13rem, 1fr) repeat(3, minmax(5.8rem, 0.38fr));
  }

  .run-header {
    background: color-mix(in srgb, var(--sl-color-gray-6) 58%, transparent);
    color: var(--sl-color-gray-3);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .run-header > *,
  .run-row > * {
    align-self: start;
    min-width: 0;
    overflow-wrap: anywhere;
    padding: 0.55rem 0.7rem;
    vertical-align: top;
  }

  .run-header > [role="columnheader"],
  .run-row > [role="cell"] {
    vertical-align: top;
  }

  .run-header > :not(:first-child) {
    text-align: center;
  }

  .run-row {
    border-top: 1px solid var(--sl-color-gray-6);
  }

  .run-row:first-of-type {
    border-top: 0;
  }

  .run-name {
    display: grid;
    gap: 0.12rem;
  }

  .metric-cell {
    display: grid;
    gap: 0.12rem;
    justify-items: center;
    text-align: center;
  }

  .run-name h3 {
    color: var(--sl-color-white);
    font-size: 0.94rem;
    line-height: 1.3;
    overflow-wrap: anywhere;
  }

  .run-name h3 span {
    color: var(--sl-color-gray-3);
    font-weight: 500;
  }

  .run-name p,
  .metric-detail,
  .cell-label {
    color: var(--sl-color-gray-3);
    font-size: 0.76rem;
  }

  .metric-value {
    color: var(--sl-color-white);
    display: block;
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.35;
    text-align: center;
    white-space: nowrap;
  }

  .cell-label {
    display: none;
  }

  .detail-tables {
    display: grid;
    gap: 1.1rem;
    margin-top: 1.4rem;
  }

  .detail-section {
    display: grid;
    gap: 0.25rem;
  }

  .detail-section h3 {
    color: var(--sl-color-white);
    font-size: 0.98rem;
    line-height: 1.3;
  }

  .sort-note {
    color: var(--sl-color-gray-3);
    font-size: 0.78rem;
    line-height: 1.35;
  }

  .detail-table-wrap {
    margin-top: 0.2rem;
    overflow-x: auto;
    width: 100%;
  }

  .cost-table,
  .timing-table {
    min-width: min(100%, 40rem);
  }

  @media (max-width: 38rem) {
    .run-header {
      display: none;
    }

    .run-row {
      display: block;
      padding: 0.85rem;
    }

    .run-row {
      border-top: 1px solid var(--sl-color-gray-6);
    }

    .run-row:first-child {
      border-top: 0;
    }

    .run-row > * {
      padding: 0;
    }

    .metric-cell {
      display: inline-grid;
      justify-items: start;
      margin: 0.65rem 0.9rem 0 0;
      min-width: 6rem;
      text-align: left;
    }

    .metric-value {
      text-align: left;
    }

    .cell-label {
      display: inline;
    }
  }
</style>
