{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://warden.dev/schemas/jsonl-v1.json",
  "title": "Warden JSONL Output",
  "description": "Schema for a single line in Warden's JSONL output. Finalized run logs contain chunk records plus a summary record; legacy skill and fix-evaluation records remain parseable. Generated from packages/warden/src/cli/output/jsonl-schema-gen.ts — do not edit by hand.",
  "anyOf": [
    {
      "$ref": "#/$defs/ChunkRecord"
    },
    {
      "$ref": "#/$defs/SkillRecord"
    },
    {
      "$ref": "#/$defs/SummaryRecord"
    },
    {
      "$ref": "#/$defs/FixEvaluationRecord"
    }
  ],
  "$defs": {
    "ChunkRecord": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "number",
          "const": 1
        },
        "run": {
          "$ref": "#/$defs/RunMetadata"
        },
        "skill": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "chunk": {
          "type": "object",
          "properties": {
            "file": {
              "type": "string"
            },
            "index": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "total": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "lineRange": {
              "type": "string"
            }
          },
          "required": [
            "file",
            "index",
            "total",
            "lineRange"
          ],
          "additionalProperties": false
        },
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "error",
            "skipped"
          ]
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Finding"
          }
        },
        "usageBreakdown": {
          "$ref": "#/$defs/UsageBreakdown"
        },
        "durationMs": {
          "type": "number",
          "minimum": 0
        },
        "error": {
          "$ref": "#/$defs/SkillError"
        },
        "skippedFiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SkippedFile"
          }
        },
        "trace": {
          "$ref": "#/$defs/HunkTrace"
        },
        "verifierRejections": {
          "$ref": "#/$defs/__schema6"
        }
      },
      "required": [
        "schemaVersion",
        "run",
        "skill",
        "chunk",
        "status",
        "findings",
        "durationMs"
      ],
      "additionalProperties": false
    },
    "RunMetadata": {
      "type": "object",
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
        },
        "durationMs": {
          "type": "number",
          "minimum": 0
        },
        "cwd": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "traceId": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "headSha": {
          "type": "string"
        }
      },
      "required": [
        "timestamp",
        "durationMs",
        "cwd",
        "runId"
      ],
      "additionalProperties": false
    },
    "Finding": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "verification": {
          "type": "string"
        },
        "location": {
          "$ref": "#/$defs/Location"
        },
        "additionalLocations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Location"
          }
        },
        "sourceSnippet": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            },
            "language": {
              "type": "string"
            },
            "startLine": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "endLine": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "targetStartLine": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "targetEndLine": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "lines": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "line": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "content": {
                    "type": "string"
                  },
                  "highlighted": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "line",
                  "content"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "path",
            "startLine",
            "endLine",
            "targetStartLine",
            "targetEndLine",
            "lines"
          ],
          "additionalProperties": false
        },
        "elapsedMs": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "id",
        "severity",
        "title",
        "description"
      ],
      "additionalProperties": false
    },
    "Location": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "startLine": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "endLine": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "path",
        "startLine"
      ],
      "additionalProperties": false
    },
    "UsageBreakdown": {
      "type": "object",
      "properties": {
        "scan": {
          "$ref": "#/$defs/__schema0"
        },
        "auxiliary": {
          "$ref": "#/$defs/__schema5"
        },
        "total": {
          "$ref": "#/$defs/UsageBreakdownEntry"
        }
      },
      "required": [
        "total"
      ],
      "additionalProperties": false,
      "anyOf": [
        {
          "required": [
            "scan"
          ]
        },
        {
          "required": [
            "auxiliary"
          ]
        }
      ]
    },
    "__schema0": {
      "$ref": "#/$defs/UsageBreakdownEntry"
    },
    "UsageBreakdownEntry": {
      "type": "object",
      "properties": {
        "model": {
          "$ref": "#/$defs/__schema1"
        },
        "models": {
          "$ref": "#/$defs/__schema2"
        },
        "runtime": {
          "$ref": "#/$defs/__schema3"
        },
        "runtimes": {
          "$ref": "#/$defs/__schema4"
        },
        "usage": {
          "$ref": "#/$defs/UsageStats"
        }
      },
      "required": [
        "usage"
      ],
      "additionalProperties": false
    },
    "__schema1": {
      "type": "string"
    },
    "__schema2": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "__schema3": {
      "type": "string"
    },
    "__schema4": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "UsageStats": {
      "type": "object",
      "properties": {
        "inputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "outputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cacheReadInputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cacheCreationInputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cacheCreation5mInputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cacheCreation1hInputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "webSearchRequests": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "costUSD": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "inputTokens",
        "outputTokens",
        "costUSD"
      ],
      "additionalProperties": false
    },
    "__schema5": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "$ref": "#/$defs/UsageBreakdownEntry"
      }
    },
    "SkillError": {
      "type": "object",
      "properties": {
        "code": {
          "$ref": "#/$defs/ErrorCode"
        },
        "message": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "additionalProperties": false
    },
    "ErrorCode": {
      "type": "string",
      "enum": [
        "auth_failed",
        "provider_unavailable",
        "sdk_error",
        "subprocess_failure",
        "max_turns",
        "aborted",
        "all_hunks_failed",
        "invalid_model_selector",
        "skill_resolution_failed",
        "extraction_invalid_json",
        "extraction_unbalanced_json",
        "extraction_no_findings_json",
        "extraction_missing_findings_key",
        "extraction_findings_not_array",
        "extraction_llm_failed",
        "extraction_llm_timeout",
        "extraction_no_api_key",
        "unknown"
      ]
    },
    "SkippedFile": {
      "type": "object",
      "properties": {
        "filename": {
          "type": "string"
        },
        "reason": {
          "type": "string",
          "enum": [
            "pattern",
            "builtin",
            "ignored:builtin",
            "ignored:user",
            "ignored:generated",
            "limit:file_size",
            "limit:file_lines",
            "limit:file_read",
            "limit:file_count",
            "limit:changed_lines",
            "limit:missing_patch"
          ]
        },
        "pattern": {
          "type": "string"
        }
      },
      "required": [
        "filename",
        "reason"
      ],
      "additionalProperties": false
    },
    "HunkTrace": {
      "type": "object",
      "properties": {
        "filename": {
          "type": "string"
        },
        "lineRange": {
          "type": "string"
        },
        "runtime": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "traceId": {
          "type": "string"
        },
        "spanId": {
          "type": "string"
        },
        "responseId": {
          "type": "string"
        },
        "responseModel": {
          "type": "string"
        },
        "sessionId": {
          "type": "string"
        },
        "durationMs": {
          "type": "number",
          "minimum": 0
        },
        "durationApiMs": {
          "type": "number",
          "minimum": 0
        },
        "numTurns": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "spans": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TraceSpan"
          }
        }
      },
      "required": [
        "filename",
        "lineRange",
        "runtime",
        "status"
      ],
      "additionalProperties": false
    },
    "TraceSpan": {
      "type": "object",
      "properties": {
        "traceId": {
          "type": "string"
        },
        "spanId": {
          "type": "string"
        },
        "parentSpanId": {
          "type": "string"
        },
        "op": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "startTimeUnixMs": {
          "type": "number",
          "minimum": 0
        },
        "endTimeUnixMs": {
          "type": "number",
          "minimum": 0
        },
        "durationMs": {
          "type": "number",
          "minimum": 0
        },
        "status": {
          "type": "string"
        },
        "origin": {
          "type": "string"
        },
        "attributes": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              },
              {
                "type": "array",
                "items": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "number"
                    },
                    {
                      "type": "boolean"
                    }
                  ]
                }
              }
            ]
          }
        }
      },
      "required": [
        "traceId",
        "spanId"
      ],
      "additionalProperties": false
    },
    "__schema6": {
      "type": "object",
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "count",
        "reasons"
      ],
      "additionalProperties": false
    },
    "SkillRecord": {
      "type": "object",
      "properties": {
        "skill": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Finding"
          }
        },
        "metadata": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        },
        "durationMs": {
          "type": "number",
          "minimum": 0
        },
        "usage": {
          "$ref": "#/$defs/UsageStats"
        },
        "skippedFiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SkippedFile"
          }
        },
        "failedHunks": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "failedExtractions": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "hunkFailures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/HunkFailure"
          }
        },
        "traces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/HunkTrace"
          }
        },
        "error": {
          "$ref": "#/$defs/SkillError"
        },
        "verifierRejections": {
          "$ref": "#/$defs/__schema6"
        },
        "auxiliaryUsage": {
          "$ref": "#/$defs/AuxiliaryUsage"
        },
        "auxiliaryUsageAttribution": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "model": {
                "$ref": "#/$defs/__schema1"
              },
              "models": {
                "$ref": "#/$defs/__schema2"
              },
              "runtime": {
                "$ref": "#/$defs/__schema3"
              },
              "runtimes": {
                "$ref": "#/$defs/__schema4"
              }
            },
            "additionalProperties": false
          }
        },
        "files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/FileRecord"
          }
        },
        "model": {
          "type": "string"
        },
        "runtime": {
          "type": "string"
        },
        "run": {
          "$ref": "#/$defs/RunMetadata"
        },
        "usageBreakdown": {
          "$ref": "#/$defs/UsageBreakdown"
        }
      },
      "required": [
        "skill",
        "summary",
        "findings",
        "run"
      ],
      "additionalProperties": false
    },
    "HunkFailure": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "analysis",
            "extraction"
          ]
        },
        "filename": {
          "type": "string"
        },
        "lineRange": {
          "type": "string"
        },
        "code": {
          "$ref": "#/$defs/ErrorCode"
        },
        "message": {
          "type": "string"
        },
        "preview": {
          "type": "string"
        },
        "attempts": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "type",
        "filename",
        "lineRange",
        "code",
        "message"
      ],
      "additionalProperties": false
    },
    "AuxiliaryUsage": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "$ref": "#/$defs/UsageStats"
      }
    },
    "FileRecord": {
      "type": "object",
      "properties": {
        "filename": {
          "type": "string"
        },
        "findings": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "durationMs": {
          "type": "number",
          "minimum": 0
        },
        "usage": {
          "$ref": "#/$defs/UsageStats"
        }
      },
      "required": [
        "filename",
        "findings"
      ],
      "additionalProperties": false
    },
    "SummaryRecord": {
      "type": "object",
      "properties": {
        "run": {
          "$ref": "#/$defs/RunMetadata"
        },
        "type": {
          "type": "string",
          "const": "summary"
        },
        "totalFindings": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "bySeverity": {
          "type": "object",
          "properties": {
            "high": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "medium": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "low": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "high",
            "medium",
            "low"
          ],
          "additionalProperties": false
        },
        "usageBreakdown": {
          "$ref": "#/$defs/UsageBreakdown"
        },
        "totalSkippedFiles": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "failedSkills": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "totalFailedHunks": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "totalFailedExtractions": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "totalVerifierRejections": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "error": {
          "$ref": "#/$defs/SkillError"
        }
      },
      "required": [
        "run",
        "type",
        "totalFindings",
        "bySeverity"
      ],
      "additionalProperties": false
    },
    "FixEvaluationRecord": {
      "type": "object",
      "properties": {
        "run": {
          "$ref": "#/$defs/RunMetadata"
        },
        "type": {
          "type": "string",
          "const": "fix-evaluation"
        },
        "evaluated": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "resolved": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "needsAttention": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "skipped": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "failedEvaluations": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "usage": {
          "$ref": "#/$defs/UsageStats"
        },
        "evaluations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/FixEvalDetail"
          }
        }
      },
      "required": [
        "run",
        "type",
        "evaluated",
        "resolved",
        "needsAttention",
        "skipped",
        "failedEvaluations"
      ],
      "additionalProperties": false
    },
    "FixEvalDetail": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "findingId": {
          "type": "string"
        },
        "verdict": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "not_attempted",
                "attempted_failed",
                "resolved"
              ]
            },
            {
              "type": "string",
              "const": "re_detected"
            },
            {
              "type": "string",
              "const": "eval_error"
            }
          ]
        },
        "reasoning": {
          "type": "string"
        },
        "durationMs": {
          "type": "number",
          "minimum": 0
        },
        "usage": {
          "$ref": "#/$defs/UsageStats"
        },
        "usedFallback": {
          "type": "boolean"
        }
      },
      "required": [
        "path",
        "line",
        "verdict",
        "durationMs",
        "usage"
      ],
